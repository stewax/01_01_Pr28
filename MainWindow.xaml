<Window x:Class="Kino_Kazakov.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Kino_Kazakov"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Button Click="Clubs" Height="25" Content="Клубы" VerticalAlignment="Top" HorizontalAlignment="Left" Margin="10 10 0 0" Width="100" Background="#FF46FD00" Foreground="White" BorderBrush="#FF46FD00" />
        <Button Click="Users" Height="25" Content="Пользователи" VerticalAlignment="Top" HorizontalAlignment="Left" Margin="115 10 0 0" Width="100" Background="#FF46FD00" Foreground="White" BorderBrush="#FF46FD00" />
        <Frame x:Name="frame" Visibility="Hidden" Margin="0 40 0 0"/>
    </Grid>
</Window>
