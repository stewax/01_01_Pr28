<Page x:Class="Kino_Kazakov.Pages.Users.Add"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Kino_Kazakov.Pages.Users"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Add" Background="White">

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="150"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" VerticalAlignment="Top" HorizontalAlignment="Left">
            <Image Source="/Images/ic-manicon.png" Width="100" Height="100" Margin="0,0,0,10"/>

            <Button Click="AddUser"
                    x:Name="BthAdd" 
                    Content="Добавить" 
                    Background="#FF4CFF00" Foreground="White" 
                    Width="100" Height="30" BorderThickness="0" FontWeight="SemiBold"/>
        </StackPanel>

        <StackPanel Grid.Column="1" Margin="10,0,20,0">
            <TextBlock Text="Дата аренды:" Margin="0,0,0,5"/>
            <DatePicker x:Name="RentStart" Height="30" Margin="0,0,0,15" VerticalContentAlignment="Center"/>

            <TextBlock Text="Время анедны:" Margin="0,0,0,5"/>
            <TextBox x:Name="RentTime" Height="30" Margin="0,0,0,15" VerticalContentAlignment="Center"/>

            <TextBlock Text="Фамилия Имя и Отчество:" Margin="0,0,0,5"/>
            <TextBox x:Name="FIO" Height="30" Margin="0,0,0,15" VerticalContentAlignment="Center"/>
        </StackPanel>

        <StackPanel Grid.Column="2" Margin="10,0,10,0">
            <TextBlock Text="Продолжительность:" Margin="0,0,0,5"/>
            <TextBox x:Name="Duration" Height="30" Margin="0,0,0,15" VerticalContentAlignment="Center"/>

            <TextBlock Text="Клуб:" Margin="0,0,0,5"/>
            <ComboBox x:Name="Clubs" Height="30" VerticalContentAlignment="Center">
            </ComboBox>
        </StackPanel>
    </Grid>
</Page>
