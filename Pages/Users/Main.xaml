<Page x:Class="Kino_Kazakov.Pages.Users.Main"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Kino_Kazakov.Pages.Users"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Main" Loaded="Page_Loaded">

    <Grid>
        <Grid Margin="20" Background="#FFF0F0F0">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Top" Margin="10">
                <StackPanel Orientation="Vertical" Margin="0 0 10 0">
                    <Label Content="Поиск по ФИО:"/>
                    <TextBox x:Name="TBoxSearch" Width="200" TextChanged="FilterChanged"/>
                </StackPanel>

                <StackPanel Orientation="Vertical">
                    <Label Content="Фильтр по клубу:"/>
                    <ComboBox x:Name="CBoxFilter" Width="150" SelectionChanged="FilterChanged"/>
                </StackPanel>

                <StackPanel Orientation="Vertical" Margin="10 0 0 0">
                    <Label Content="Сортировка:"/>
                    <ComboBox x:Name="CBoxSort" Width="120" SelectionChanged="FilterChanged">
                        <ComboBoxItem Content="Без сортировки"/>
                        <ComboBoxItem Content="ФИО (А-Я)"/>
                        <ComboBoxItem Content="ФИО (Я-А)"/>
                    </ComboBox>
                </StackPanel>
            </StackPanel>

            <ScrollViewer Margin="0 60 0 50">
                <StackPanel x:Name="ParentView"/>
            </ScrollViewer>

            <Button
                x:Name="BtnAdd"
                Click="AddClub"
                Height="25"
                Content="Добавить"
                VerticalAlignment="Bottom"
                Margin="10"
                HorizontalAlignment="Right"
                Width="100"
                Background="#FF46FD00"
                BorderBrush="#FF46FD00"
                Foreground="White"/>
        </Grid>
    </Grid>
</Page>