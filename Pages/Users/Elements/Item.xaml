<UserControl x:Class="Kino_Kazakov.Pages.Users.Elements.Item"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Kino_Kazakov.Pages.Users.Elements"
              mc:Ignorable="d" >
    <Grid Margin="10" Background="White">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="100"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Image Width="80" Height="80" VerticalAlignment="Top" Margin="10" Source="/Images/ic-manicon.png"/>
        <Button Click="EditUser" Height="25" Content="Изменить" VerticalAlignment="Top" Margin="10 95 10 0"
            Background="#FF46FD00" BorderBrush="#FF46FD00" Foreground="White"/>
        <Button Click="DeleteUser" Height="25" Content="Удалить" VerticalAlignment="Top" Margin="10 125 10 10"
            Background="#FFCD1E1E" BorderBrush="#FFCD1E1E" Foreground="White"/>
        <StackPanel Orientation="Vertical" Grid.Column="1" Margin="0 0 10 15">
            <Grid Margin="0 0 0 15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Vertical" Width="250" Margin="0 0 20 0">
                    <Label Content="Дата аренды:"/>
                    <DatePicker x:Name="RentStart" Text="12.02.2026" Margin="0 0 0 15"/>

                    <Label Content="Время аренды:"/>
                    <TextBox x:Name="RentTime" Text="14:01"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Vertical" Width="250">
                    <Label Content="Продолжительность:"/>
                    <TextBox x:Name="Duration" Text="121" Margin="0 0 0 15" Height="24"/>

                    <Label Content="Клуб:"/>
                    <TextBox x:Name="Club" Text="asd"/>
                </StackPanel>
            </Grid>
            
            <Label Content="ФИО"/>
            <TextBox x:Name="FIO" Text="Казаков Михаил Сергеевич"/>
        </StackPanel>
    </Grid>
</UserControl>
